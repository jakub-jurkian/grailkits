# GrailKits environment template
# Copy this file to .env and adjust values for your local setup.

# Core infrastructure
POSTGRES_USER=root
POSTGRES_PASSWORD=rootpassword
POSTGRES_DB=grailkits_db
DB_HOST=postgres
DB_PORT=5432
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=grailkits_db

MONGODB_URI=mongodb://root:rootpassword@mongo:27017/grailkits?authSource=admin

# Database connection string used by catalog and order services
DATABASE_URL=postgres://root:rootpassword@postgres:5432/grailkits_db

# Service ports
PORT=3000

# Gateway service targets
CATALOG_SERVICE_URL=http://catalog-service:3001
REVIEW_SERVICE_URL=http://review-service:3002
ORDER_SERVICE_URL=http://order-service:3003